# ===================================================================
# ProDigiChat — environment variable template
#
# Copy to `.env.development` (gitignored) and fill in real values for
# local development, or to `.env.production` for production deploys.
# DO NOT commit any file with real secrets in it.
# ===================================================================

# ---- Database ----
# MongoDB connection string. URL-encode any special characters in the
# password (e.g. "@" becomes "%40").
MONGODB_URI=mongodb://localhost:27017/prodigichat

# ---- Upstash Redis (rate limiting + distributed locks) ----
# Optional in development; required in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- NextAuth ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ---- Google OAuth (optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Meta (Facebook) WhatsApp Cloud API ----
NEXT_PUBLIC_META_APP_ID=
META_APP_ID=
META_APP_SECRET=
NEXT_PUBLIC_META_CONFIG_ID=
META_API_VERSION=v22.0
NEXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:3000/api/whatsapp/oauth/callback
META_OAUTH_REDIRECT_URI=http://localhost:3000/api/whatsapp/oauth/callback

# ---- WhatsApp webhook ----
# Verify token: any random string you also paste into the Meta dashboard.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Webhook secret: shared secret used by HMAC verification of incoming
# payloads. Must match the value you configure on Meta.
WHATSAPP_WEBHOOK_SECRET=

# ---- Field-level encryption ----
# 32+ character string used to derive AES-256-GCM keys for stored
# credentials. Required in production. In development, the app will
# refuse to start unless this is set; if you really want plaintext
# storage in dev, set ENCRYPTION_KEY=dev-only-do-not-use-in-prod (>=32
# chars).
ENCRYPTION_KEY=

# ---- Cron auth ----
# Bearer token required by /api/cron/* endpoints.
CRON_SECRET=

# ---- Transactional email (SMTP) ----
# Used for password reset, team invites, and email notifications.
# Provider-agnostic: works with AWS SES SMTP, Mailgun, Postmark, Gmail,
# etc. If left blank, emails are logged to the server console instead of
# sent (so local dev keeps working) — production logs a warning.
SMTP_HOST=
SMTP_PORT=587
# "true" for implicit TLS (port 465); leave blank for STARTTLS (587).
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
# Default From address, e.g. "ProDigiChat <no-reply@yourdomain.com>"
SMTP_FROM=

# ---- Public app URL ----
# Also used as the base for links in transactional emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Runtime ----
NODE_ENV=development
