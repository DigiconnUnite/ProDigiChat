# ==========================================
# VERCEL DEPLOYMENT - Environment Variables
# ==========================================
# Copy this file to .env.production and fill in your values
# Add these in Vercel Dashboard → Project → Settings → Environment Variables

# ==========================================
# REQUIRED: Database (MongoDB Atlas)
# ==========================================
# Get from MongoDB Atlas - choose "Connect" → "Connect your application"
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# ==========================================
# REQUIRED: NextAuth.js
# ==========================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-generated-secret-key
NEXTAUTH_URL=https://your-app-name.vercel.app

# ==========================================
# REQUIRED: WhatsApp / Meta Configuration
# ==========================================
# Get from Meta Developer Portal (developers.facebook.com)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_OAUTH_REDIRECT_URI=https://your-app-name.vercel.app/api/whatsapp/oauth/callback

# Meta API Version (defaults to v21.0, can be overridden to v22.0 or later)
META_API_VERSION=v21.0

# Generate a secure random string for webhook verification
WHATSAPP_WEBHOOK_SECRET=your-webhook-secret-key

# ==========================================
# OPTIONAL: Email (SMTP)
# ==========================================
# For Gmail: Use App Password (not your regular password)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-email@gmail.com
EMAIL_SERVER_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# ==========================================
# OPTIONAL: Redis (for message queue)
# ==========================================
# Use Vercel KV (vercel.com/kv) or Upstash (upstash.com)
# Format: redis://default:password@host:port
REDIS_URL=redis://default:password@host:port

# ==========================================
# OPTIONAL: AWS S3 (for file storage)
# ==========================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1

# ==========================================
# OPTIONAL: Google OAuth (if enabled)
# ==========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
